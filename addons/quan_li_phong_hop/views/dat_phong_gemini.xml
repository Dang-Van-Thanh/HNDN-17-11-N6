<odoo>
    <data>
        <record id="view_dat_phong_gemini_wizard_form" model="ir.ui.view">
            <field name="name">dat_phong_gemini_wizard_form</field>
            <field name="model">dat_phong.gemini.wizard</field>
            <field name="arch" type="xml">
                <form string="Gợi ý & Đặt phòng AI Gemini">
                    <sheet>
                        <group>
                            <field name="nguoi_muon_id"/>
                            <field name="thoi_gian_muon_du_kien"/>
                            <field name="thoi_gian_tra_du_kien"/>
                            <field name="suc_chua"/>
                            <field name="phong_id"/>
                        </group>
                        <group>
                            <field name="goi_y_ai" readonly="1"/>
                        </group>
                    </sheet>
                    <footer>
                        <button string="Gợi ý phòng" type="object" name="onchange_suggest" class="btn-primary"/>
                        <button string="Đặt phòng" type="object" name="action_confirm_booking" class="btn-success"/>
                        <button string="Hủy" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_dat_phong_gemini_wizard" model="ir.actions.act_window">
            <field name="name">Gợi ý & Đặt phòng AI Gemini</field>
            <field name="res_model">dat_phong.gemini.wizard</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="view_dat_phong_gemini_wizard_form"/>
            <field name="target">new</field>
        </record>

        <menuitem id="menu_dat_phong_ai_gemini" 
                  name="Đặt phòng AI Gemini" 
                  parent="menu_dat_phong" 
                  action="action_dat_phong_gemini_wizard" 
                  sequence="1"/>
    </data>
</odoo>