<odoo>
    <data>
        <record id="view_dat_phong_gemini_wizard_form" model="ir.ui.view">
            <field name="name">dat_phong_gemini_wizard_form</field>
            <field name="model">dat_phong.gemini.wizard</field>
            <field name="arch" type="xml">
                <form string="Gợi ý AI Gemini">
                    <sheet>
                        <div class="alert alert-info" role="alert">
                            <strong>💡 Hướng dẫn:</strong> Nhập yêu cầu đặt phòng bằng ngôn ngữ tự nhiên. AI Gemini sẽ phân tích và gợi ý phòng phù hợp.
                        </div>

                        <group col="1">
                            <group string="👤 Thông tin">
                                <field name="nguoi_muon_id"/>
                            </group>
                            <group string="📝 Yêu cầu">
                                <field name="yeu_cau_text" placeholder="Ví dụ chuẩn: Tôi cần phòng họp cho 10 người vào ngày 22/03/2026 bắt đầu 9:00, thời lượng 30 phút"/>
                            </group>
                            <group string="🤖 Gợi ý AI">
                                <field name="goi_y_ai" readonly="1" placeholder="AI Gemini sẽ đưa ra gợi ý ở đây..."/>
                                <field name="phong_id" readonly="1" options="{'no_create': True, 'no_edit': True}"/>
                            </group>
                        </group>
                    </sheet>
                    <footer>
                        <button string="🤖 Lấy gợi ý AI" type="object" name="action_get_ai_suggestion" class="btn-info"
                                attrs="{'invisible': [('yeu_cau_text', '=', False)]}"/>
                        <button string="✅ Đặt phòng theo gợi ý" type="object" name="action_dat_phong_theo_goi_y" class="btn-success"
                                attrs="{'invisible': [('phong_id', '=', False)]}"/>
                        <button string="❌ Hủy" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_dat_phong_gemini_wizard" model="ir.actions.act_window">
            <field name="name">Gợi ý AI Gemini</field>
            <field name="res_model">dat_phong.gemini.wizard</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="view_dat_phong_gemini_wizard_form"/>
            <field name="target">new</field>
        </record>

        <menuitem id="menu_dat_phong_ai_gemini" 
                  name="Gợi ý AI Gemini" 
                  parent="menu_dat_phong" 
                  action="action_dat_phong_gemini_wizard" 
                  sequence="1"/>
    </data>
</odoo>